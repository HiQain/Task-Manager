## Copy to `.env` for local development only.
## Never commit your real `.env` to git.

# Required (MySQL connection string)
DATABASE_URL="mysql://user:password@host:3306/database"

# Recommended (sessions)
SESSION_SECRET="change-me-to-a-long-random-string"

# Optional
PORT=5000
NODE_ENV=development

# Optional (cookie settings behind proxies)
SESSION_COOKIE_SAME_SITE="lax"   # lax | strict | none
SESSION_COOKIE_SECURE="false"    # true | false

# Optional (Web Push notifications)
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@example.com"

# Optional (storage quota per user)
STORAGE_QUOTA_BYTES=2147483648
